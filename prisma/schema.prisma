// Prisma schema for Viora Smart Academy (VSA).
//
// Local dev: SQLite (file at ./prisma/dev.db) — zero external services.
//   DATABASE_URL = "file:./dev.db"
// For production, swap provider to "postgresql" and point DATABASE_URL /
// DIRECT_URL at your Postgres (e.g. Supabase pooled + direct connections).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String     @id @default(cuid())
  email      String     @unique
  name       String
  passwordHash String?
  plan       String     @default("free") // free | pro | family
  role       String     @default("user") // user | admin
  streak     Int        @default(0)
  lastActive DateTime   @default(now())
  createdAt  DateTime   @default(now())
  progress   Progress[]
  attempts   Attempt[]
  messages   ChatMessage[]
  snapshots  BoardSnapshot[]
}

model Lesson {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  topic       String
  durationSec Int
  isPro       Boolean    @default(false)
  // Lesson script JSON (LessonScript)
  script      String     // JSON-encoded
  createdAt   DateTime   @default(now())
  progress    Progress[]
  attempts    Attempt[]
  messages    ChatMessage[]
  snapshots   BoardSnapshot[]
}

model Progress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  score       Int      @default(0)
  completedAt DateTime?
  user        User     @relation(fields: [userId], references: [id])
  lesson      Lesson   @relation(fields: [lessonId], references: [id])
  @@unique([userId, lessonId])
}

model Attempt {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  score     Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  lesson    Lesson   @relation(fields: [lessonId], references: [id])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String?
  role      String   // user | assistant | system
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  lesson    Lesson?  @relation(fields: [lessonId], references: [id])
}

model BoardSnapshot {
  id        String   @id @default(cuid())
  uuid      String   @unique
  userId    String?
  lessonId  String?
  stateJson String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
  lesson    Lesson?  @relation(fields: [lessonId], references: [id])
}
